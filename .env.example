# Mustang RideShare — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:  mongodb://localhost:27017/mustang-rideshare
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/mustang-rideshare
MONGODB_URI=mongodb://localhost:27017/mustang-rideshare

# JWT secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Server port
PORT=5000

# Set to "production" on deployed servers
NODE_ENV=development
