<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow">
        <div class="card-header bg-warning text-dark">
          <h3 class="mb-0">Verify Your Email</h3>
        </div>
        <div class="card-body">
          
          <% if (errorMessage) { %>
            <div class="alert alert-danger"><%= errorMessage %></div>
          <% } %>

          <p class="lead">We sent a verification code to <strong><%= email %></strong></p>
          <p class="text-muted small">Check your SMSU/MinnState email inbox (and spam folder).</p>

          <form action="/verify" method="POST">
            <input type="hidden" name="email" value="<%= email %>">

            <div class="mb-3">
              <label for="code" class="form-label">Enter 6-Digit Code</label>
              <input 
                type="text" 
                name="code" 
                id="code" 
                class="form-control form-control-lg text-center" 
                placeholder="123456" 
                maxlength="6"
                required
              >
            </div>

            <div class="d-grid">
              <button type="submit" class="btn btn-primary">Verify Account</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>