<%- include('../partials/head', { title: 'Post New Ride' }) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<%- include('../partials/navbar') %>

<div class="container my-4" style="max-width:820px;">

  <div class="page-header-accent mb-4">
    <h2>Post a New Ride</h2>
    <p>Share a ride from SMSU to nearby cities — pin your route on the map and other Mustangs can join.</p>
  </div>

  <% if (locals.error && error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form method="POST" action="/rides/new" id="newRideForm">
    <!-- Hidden coordinate fields populated by map clicks -->
    <input type="hidden" name="departureLat" id="departureLat">
    <input type="hidden" name="departureLng" id="departureLng">
    <input type="hidden" name="destinationLat" id="destinationLat">
    <input type="hidden" name="destinationLng" id="destinationLng">

    <!-- ---- Map section ---- -->
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span>📍 Pin Your Route on the Map</span>
        <span class="badge bg-warning text-dark" id="mapStepBadge">Step 1: Click departure</span>
      </div>
      <div id="pickMap" style="height:380px;"></div>
      <div class="card-body py-2 px-3">
        <div class="row g-2 small text-muted">
          <div class="col-sm-6">
            🟢 <strong>Departure:</strong> <span id="departureLabel">Not pinned yet</span>
          </div>
          <div class="col-sm-6">
            🏁 <strong>Destination:</strong> <span id="destinationLabel">Not pinned yet</span>
          </div>
        </div>
        <p class="text-muted small mt-1 mb-0">
          <em>Click once to set departure, click again to set destination. You can also type the names below.</em>
        </p>
        <button type="button" class="btn btn-outline-secondary btn-sm mt-2" onclick="resetMapPins()">
          🔄 Reset pins
        </button>
      </div>
    </div>

    <!-- ---- Ride details ---- -->
    <div class="card mb-4">
      <div class="card-header">🚗 Ride Details</div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">From (Departure Location)</label>
            <input type="text" class="form-control" name="departureLocation" id="departureLocationInput"
              placeholder="e.g. SMSU Campus" required />
          </div>
          <div class="col-md-6">
            <label class="form-label">To (Destination)</label>
            <input type="text" class="form-control" name="destination" id="destinationInput"
              placeholder="e.g. Sioux Falls, SD" required />
          </div>

          <div class="col-md-4">
            <label class="form-label">Date</label>
            <input type="date" class="form-control" name="departureDate" required />
          </div>
          <div class="col-md-4">
            <label class="form-label">Time</label>
            <input type="time" class="form-control" name="departureTime" required />
          </div>
          <div class="col-md-4">
            <label class="form-label">Available Seats</label>
            <input type="number" min="1" max="8" value="3" class="form-control" name="availableSeats" required />
          </div>

          <div class="col-12">
            <label class="form-label">Vehicle Info <span class="text-muted fw-normal">(optional)</span></label>
            <input type="text" class="form-control" name="vehicleInfo"
              placeholder="e.g. Blue Honda Civic — MN ABC-123" />
          </div>

          <div class="col-12">
            <label class="form-label">Notes for passengers <span class="text-muted fw-normal">(optional)</span></label>
            <textarea class="form-control" rows="3" name="notes"
              placeholder="e.g. Leaving from Central Field parking lot, please be 10 min early."></textarea>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between">
      <a href="/dashboard/driver" class="btn btn-outline-secondary">Cancel</a>
      <button type="submit" class="btn btn-gold px-4">🐎 Post Ride</button>
    </div>
  </form>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
// SMSU / Marshall MN default center
const map = L.map('pickMap').setView([44.4469, -95.7882], 12);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '© <a href="https://openstreetmap.org/copyright">OpenStreetMap</a>',
  maxZoom: 19,
}).addTo(map);

let step = 'departure'; // 'departure' | 'destination' | 'done'
let departureMarker = null;
let destinationMarker = null;

function makePin(emoji) {
  return L.divIcon({
    html: `<div style="font-size:32px;line-height:1;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.35))">${emoji}</div>`,
    className: '', iconSize: [32, 32], iconAnchor: [16, 32], popupAnchor: [0, -34],
  });
}

function updateBadge() {
  const badge = document.getElementById('mapStepBadge');
  if (step === 'departure') {
    badge.textContent = 'Step 1: Click departure';
    badge.className = 'badge bg-warning text-dark';
  } else if (step === 'destination') {
    badge.textContent = 'Step 2: Click destination';
    badge.className = 'badge bg-primary';
  } else {
    badge.textContent = '✅ Route pinned!';
    badge.className = 'badge bg-success';
  }
}

function reverseGeocode(lat, lng, callback) {
  // Use Nominatim free geocoder
  fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`)
    .then(r => r.json())
    .then(d => callback(d.display_name || `${lat.toFixed(4)}, ${lng.toFixed(4)}`))
    .catch(() => callback(`${lat.toFixed(4)}, ${lng.toFixed(4)}`));
}

map.on('click', function(e) {
  const { lat, lng } = e.latlng;

  if (step === 'departure') {
    if (departureMarker) map.removeLayer(departureMarker);
    departureMarker = L.marker([lat, lng], { icon: makePin('🟢') })
      .addTo(map).bindPopup('<strong>Departure</strong>').openPopup();

    document.getElementById('departureLat').value = lat;
    document.getElementById('departureLng').value = lng;
    document.getElementById('departureLabel').textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;

    // Try to fill in the text field via reverse geocoding
    reverseGeocode(lat, lng, function(name) {
      const input = document.getElementById('departureLocationInput');
      if (!input.value) {
        // Extract shorter place name
        const parts = name.split(',');
        input.value = parts.slice(0, 2).join(',').trim();
      }
      document.getElementById('departureLabel').textContent = parts[0] || name;
    });

    step = 'destination';
    updateBadge();

  } else if (step === 'destination') {
    if (destinationMarker) map.removeLayer(destinationMarker);
    destinationMarker = L.marker([lat, lng], { icon: makePin('🏁') })
      .addTo(map).bindPopup('<strong>Destination</strong>').openPopup();

    document.getElementById('destinationLat').value = lat;
    document.getElementById('destinationLng').value = lng;
    document.getElementById('destinationLabel').textContent = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;

    reverseGeocode(lat, lng, function(name) {
      const input = document.getElementById('destinationInput');
      if (!input.value) {
        const parts = name.split(',');
        input.value = parts.slice(0, 2).join(',').trim();
      }
      document.getElementById('destinationLabel').textContent = parts[0] || name;
    });

    // Draw a line between the two points
    if (departureMarker) {
      L.polyline([departureMarker.getLatLng(), [lat, lng]], {
        color: '#4b2e83', weight: 3, dashArray: '8, 6', opacity: 0.7,
      }).addTo(map);
      map.fitBounds([departureMarker.getLatLng(), [lat, lng]], { padding: [40, 40] });
    }

    step = 'done';
    updateBadge();
  }
});

function resetMapPins() {
  if (departureMarker) { map.removeLayer(departureMarker); departureMarker = null; }
  if (destinationMarker) { map.removeLayer(destinationMarker); destinationMarker = null; }
  document.getElementById('departureLat').value = '';
  document.getElementById('departureLng').value = '';
  document.getElementById('destinationLat').value = '';
  document.getElementById('destinationLng').value = '';
  document.getElementById('departureLabel').textContent = 'Not pinned yet';
  document.getElementById('destinationLabel').textContent = 'Not pinned yet';
  step = 'departure';
  updateBadge();
  // Remove route line by recreating map layers (simplest approach)
  map.eachLayer(layer => {
    if (layer instanceof L.Polyline) map.removeLayer(layer);
  });
  map.setView([44.4469, -95.7882], 12);
}

// Try to get user's current location to center map
if (navigator.geolocation) {
  navigator.geolocation.getCurrentPosition(pos => {
    map.setView([pos.coords.latitude, pos.coords.longitude], 13);
  }, () => {});
}
</script>
<%- include('../partials/footer') %>
