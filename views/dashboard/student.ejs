<%- include('../partials/head', { title: 'Student Dashboard' }) %>
<%- include('../partials/navbar') %>

<div class="container py-4">

  <div class="page-header-accent mb-4">
    <h2>Student Dashboard</h2>
    <p>Welcome back, <strong><%= user.fullName %></strong>! Browse rides, track accepted trips in real time.</p>
  </div>

  <% if (locals.success && success) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (locals.error && error) { %>
    <div class="alert alert-danger alert-dismissible fade show">
      <%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Stats row -->
  <div class="row g-3 mb-4">
    <div class="col-sm-4">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">Available Rides</div>
          <div class="summary-value"><%= availableRides.length %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-4">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">My Requests</div>
          <div class="summary-value"><%= myRequests.length %></div>
        </div>
      </div>
    </div>
    <div class="col-sm-4">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">Messages</div>
          <div class="summary-value"><%= messages.length %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Left: Available Rides -->
    <div class="col-lg-7">
      <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
          <span>🚗 Available Rides</span>
          <span class="badge"><%= availableRides.length %> found</span>
        </div>
        <div class="card-body p-0">
          <% if (availableRides.length === 0) { %>
            <p class="text-muted small p-3 mb-0">No rides available right now. Check back soon!</p>
          <% } else { %>
            <div class="list-group list-group-flush">
              <% availableRides.forEach(function(ride) { %>
                <div class="list-group-item ride-list-item px-3 py-3">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="flex-grow-1">
                      <p class="mb-1 fw-semibold" style="font-family:'Outfit',sans-serif;">
                        <%= ride.departureLocation %> &rarr; <%= ride.destination %>
                      </p>
                      <p class="mb-1 small text-muted">
                        🕐 <%= new Date(ride.departureTime).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                        &nbsp;&middot;&nbsp; 🪑 <%= ride.availableSeats %> seat(s)
                        &nbsp;&middot;&nbsp; 👤 <%= ride.driver ? ride.driver.fullName : 'Unknown' %>
                      </p>
                      <% if (ride.departureCoords && ride.departureCoords.lat) { %>
                        <span class="badge bg-success" style="font-size:0.7rem;">📍 Map pinned</span>
                      <% } %>
                      <% if (ride.notes) { %>
                        <p class="mb-0 small text-secondary fst-italic mt-1"><%= ride.notes %></p>
                      <% } %>
                    </div>
                    <% var alreadyRequested = myRequests.some(function(r) {
                      return r.ride && r.ride._id && r.ride._id.toString() === ride._id.toString();
                    }); %>
                    <div class="d-flex flex-column gap-1">
                      <% if (alreadyRequested) { %>
                        <span class="badge bg-success">✓ Requested</span>
                      <% } else { %>
                        <button class="btn btn-gold btn-sm"
                          data-bs-toggle="modal" data-bs-target="#requestModal"
                          data-ride-id="<%= ride._id %>"
                          data-ride-name="<%= ride.departureLocation %> → <%= ride.destination %>">
                          Request
                        </button>
                      <% } %>
                      <% if (ride.departureCoords && ride.departureCoords.lat) { %>
                        <a href="/tracking/<%= ride._id %>" class="btn btn-track btn-sm" target="_blank">
                          📍 Track
                        </a>
                      <% } %>
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Right: My Requests + Messages -->
    <div class="col-lg-5">
      <!-- My Requests -->
      <div class="card mb-4">
        <div class="card-header">📋 My Ride Requests</div>
        <div class="card-body p-0 small">
          <% if (myRequests.length === 0) { %>
            <p class="text-muted p-3 mb-0">No requests yet. Find a ride above!</p>
          <% } else { %>
            <ul class="list-group list-group-flush">
              <% myRequests.forEach(function(req) { %>
                <li class="list-group-item ride-list-item py-3">
                  <strong><%= req.ride ? (req.ride.departureLocation + ' → ' + req.ride.destination) : 'Ride unavailable' %></strong>
                  <% if (req.ride && req.ride.departureTime) { %>
                    <br><span class="text-muted">
                      <%= new Date(req.ride.departureTime).toLocaleString('en-US', { dateStyle: 'short', timeStyle: 'short' }) %>
                    </span>
                  <% } %>
                  <br>
                  <% if (req.status === 'Accepted') { %>
                    <span class="badge bg-success">✓ Accepted</span>
                    <% if (req.ride && req.ride._id) { %>
                      &nbsp;<a href="/tracking/<%= req.ride._id %>" class="btn btn-track btn-sm" target="_blank">🗺 Live Track</a>
                    <% } %>
                  <% } else if (req.status === 'Rejected') { %>
                    <span class="badge bg-danger">✗ Rejected</span>
                  <% } else { %>
                    <span class="badge bg-warning text-dark">⏳ Pending</span>
                    <form method="POST" action="/requests/<%= req._id %>/cancel" class="d-inline ms-1">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                    </form>
                  <% } %>
                  <% if (req.message) { %>
                    <p class="mb-0 mt-1 text-muted fst-italic">"<%= req.message %>"</p>
                  <% } %>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>

      <!-- Messages -->
      <div class="card">
        <div class="card-header">💬 Recent Messages</div>
        <div class="card-body small">
          <% if (messages.length === 0) { %>
            <p class="text-muted mb-0">No messages yet.</p>
          <% } else { %>
            <% messages.forEach(function(msg, i) { %>
              <% if (i > 0) { %><hr class="my-2"/><% } %>
              <p class="mb-1">
                <strong><%= msg.sender ? msg.sender.fullName : 'Unknown' %></strong>
                <span class="text-muted" style="font-size:0.75rem;">
                  · <%= new Date(msg.createdAt).toLocaleString('en-US', { dateStyle: 'short', timeStyle: 'short' }) %>
                </span><br/>
                <span class="fst-italic text-secondary">"<%= msg.content %>"</span>
              </p>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Request Modal -->
<div class="modal fade" id="requestModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header" style="background:var(--mustang-purple);color:white;">
        <h5 class="modal-title">🐎 Request a Ride</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="requestForm" method="POST" action="">
        <div class="modal-body">
          <p class="mb-3">Requesting: <strong id="rideNameDisplay"></strong></p>
          <label class="form-label">Message to driver <span class="text-muted fw-normal">(optional)</span></label>
          <textarea class="form-control" name="message" rows="3"
            placeholder="e.g. I'll be at the Student Center entrance at your departure time."></textarea>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-gold">Send Request</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.getElementById('requestModal').addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('rideNameDisplay').textContent = btn.getAttribute('data-ride-name');
    document.getElementById('requestForm').action = '/rides/' + btn.getAttribute('data-ride-id') + '/request';
  });
</script>
<%- include('../partials/footer') %>
