<%- include('../partials/head', { title: 'Admin Dashboard' }) %>
<%- include('../partials/navbar') %>

<main class="container py-4">

  <div class="page-header-accent mb-4">
    <h2>Admin Dashboard</h2>
    <p>Manage user accounts, rides, and platform health for Mustang RideShare.</p>
  </div>

  <% if (locals.success && success) { %>
    <div class="alert alert-success alert-dismissible fade show">
      <%= success %><button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">Total Users</div>
          <div class="summary-value"><%= totalUsers %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">Active Drivers</div>
          <div class="summary-value"><%= activeDrivers %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">Total Rides</div>
          <div class="summary-value"><%= totalRides %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card summary-card">
        <div class="card-body text-center py-3">
          <div class="summary-label">Students</div>
          <div class="summary-value"><%= users.filter(function(u){ return u.role==='student'; }).length %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- User Management (wide) -->
    <div class="col-lg-8">
      <div class="card mb-4">
        <div class="card-header">👥 User Management</div>
        <div class="card-body p-0">
          <% if (users.length === 0) { %>
            <p class="text-muted small p-3 mb-0">No users found.</p>
          <% } else { %>
            <div class="table-responsive">
              <table class="table table-sm mb-0 small">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(function(u) { %>
                    <tr>
                      <td class="fw-semibold"><%= u.fullName %></td>
                      <td class="text-muted"><%= u.email %></td>
                      <td>
                        <form method="POST" action="/admin/users/<%= u._id %>/role" class="d-flex gap-1">
                          <select name="role" class="form-select form-select-sm" style="min-width:90px;">
                            <option value="student" <%= u.role==='student'?'selected':'' %>>Student</option>
                            <option value="driver"  <%= u.role==='driver'?'selected':'' %>>Driver</option>
                            <option value="admin"   <%= u.role==='admin'?'selected':'' %>>Admin</option>
                          </select>
                          <button type="submit" class="btn btn-outline-secondary btn-sm">Set</button>
                        </form>
                      </td>
                      <td>
                        <% if (u.isActive) { %>
                          <span class="badge bg-success">Active</span>
                        <% } else { %>
                          <span class="badge bg-secondary">Inactive</span>
                        <% } %>
                      </td>
                      <td>
                        <form method="POST" action="/admin/users/<%= u._id %>/toggle">
                          <button type="submit" class="btn btn-sm <%= u.isActive ? 'btn-outline-warning' : 'btn-outline-success' %>">
                            <%= u.isActive ? 'Deactivate' : 'Activate' %>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Recent Rides -->
    <div class="col-lg-4">
      <div class="card">
        <div class="card-header">🚗 Recent Rides</div>
        <div class="card-body p-0">
          <% if (rides.length === 0) { %>
            <p class="text-muted small p-3 mb-0">No rides posted yet.</p>
          <% } else { %>
            <ul class="list-group list-group-flush small">
              <% rides.forEach(function(ride) { %>
                <li class="list-group-item ride-list-item d-flex justify-content-between align-items-start gap-2 py-2 px-3">
                  <div>
                    <strong><%= ride.departureLocation %> → <%= ride.destination %></strong><br/>
                    <span class="text-muted"><%= ride.driver ? ride.driver.fullName : 'Unknown' %></span><br/>
                    <span class="text-muted" style="font-size:0.72rem;">
                      <%= new Date(ride.departureTime).toLocaleString('en-US', { dateStyle: 'short', timeStyle: 'short' }) %>
                    </span>
                    <% if (ride.departureCoords && ride.departureCoords.lat) { %>
                      &nbsp;<span class="badge bg-success" style="font-size:0.65rem;">📍 mapped</span>
                    <% } %>
                  </div>
                  <div class="d-flex flex-column gap-1">
                    <a href="/tracking/<%= ride._id %>" class="btn btn-track btn-sm" target="_blank" title="Live Track">📍</a>
                    <form method="POST" action="/admin/rides/<%= ride._id %>/delete"
                      onsubmit="return confirm('Delete this ride?')">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Del</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<%- include('../partials/footer') %>
